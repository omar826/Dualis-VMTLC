(declare-var N Int)
(declare-var k Int)
(declare-var k1 Int)
(declare-var len Int)
(declare-var len1 Int)
(declare-var items_processed Int)
(declare-var items_processed1 Int)
(declare-var ret Int)
(declare-var ret1 Int)
(declare-var min Int)
(declare-var min1 Int)
(declare-var max Int)
(declare-var max1 Int)
(declare-rel insertHead (Int Int Int Int Int Int Int))
(declare-rel popHead (Int Int Int Int Int Int Int))
(declare-rel inv1 (Int Int Int Int Int))
(declare-rel inv2 (Int Int Int Int Int))
(declare-rel fail ())
(define-fun MAX () Int 128)
(define-fun MIN () Int -129)

(rule (=> (and (> N 0) (= k 0) (= len 0) (= min MAX) (= max MIN)) (inv1 k N min max len1)))
(rule (=> (and (inv1 k N min max len) (< k N) (insertHead k min max len min1 max1 len1) (= k1 (+ k 1))) (inv1 k1 N min1 max1 len1)))
(rule (=> (and (inv1 k N min max len) (not (< k N)) (= items_processed 0) (= ret1 MAX)) (inv2 min max len items_processed ret1)))
(rule (=> (and (inv2 min max len items_processed ret) (not (= len 0)) (popHead min max len min1 max1 len1 ret1) (= items_processed1 (+ items_processed 1))) (inv2 min1 max1 len1 items_processed1 ret1)))
(rule (=> (and (inv2 min max len items_processed ret) (= len 0) (not (= ret 0))) fail))

(query fail :print-certificate true)
