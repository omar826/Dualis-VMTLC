(declare-var N Int)
(declare-var i Int)
(declare-var i1 Int)
(declare-var len Int)
(declare-var len1 Int)
(declare-var countko Int)
(declare-var countko1 Int)
(declare-var countkt Int)
(declare-var countkt1 Int)
(declare-var k Int)
(declare-var v Int)
(declare-rel emplace (Int Int Int Int Int Int Int Int))
(declare-rel inv1 (Int Int Int Int Int))
(declare-rel fail ())

(rule (=> (and (> N 0) (= i 0) (= len 0) (= countko 0) (= countkt 0)) (inv1 i N countko countkt len)))
(rule (=> (and (inv1 i N countko countkt len) (< i N) (= k 1) (emplace k v countko countkt len countko1 countkt1 len1) (= i1 (+ i 1))) (inv1 i1 N countko1 countkt1 len1)))
(rule (=> (and (inv1 i N countko countkt len) (not (< i N)) (= k 2) (emplace k v countko countkt len countko1 countkt1 len1) (not (and (= countko1 N) (= countkt1 1)))) fail))

(query fail :print-certificate true)