(declare-rel inv (Int Int Int Int Int Int))
(declare-rel insert (Int Int Int Int Int Int Int Int Int))
(declare-rel search (Int Int Int Int Int Int))
(declare-rel fail ())
(declare-var i Int)
(declare-var i1 Int)
(declare-var max Int)
(declare-var max1 Int)
(declare-var min Int)
(declare-var min1 Int)
(declare-var len Int)
(declare-var len1 Int)
(declare-var N Int)
(declare-var noDup Int)
(declare-var noDup1 Int)
(declare-var data Int)
(declare-var ret1 Int)
(define-fun is_valid ((x Int)) Bool (or (= x 1) (= x 0)))
(define-fun MAX () Int 128)
(define-fun MIN () Int -129)

(rule (=> (and (> N 0) (= i1 0) (= max1 MIN) (= min1 MAX) (= noDup1 1) ) (inv i1 max1 min1 len1 noDup1 N)))
(rule(=> (and (inv i max min len noDup N) (is_valid noDup) (< i N) (insert i max max1 min min1 len len1 noDup noDup1) ( = i1 (+ i 1))) (inv i1 max1 min1 len1 noDup1 N)))
(rule(=> (and (inv i max min len noDup N) (is_valid noDup) (>= i N) (>= data 0) (< data N) (search data max min len noDup ret1) (= ret1 0)) fail))

(query fail :print-certificate true)
