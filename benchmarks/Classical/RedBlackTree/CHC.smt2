(declare-var N Int)
(declare-var max Int)
(declare-var max1 Int)
(declare-var min Int)
(declare-var min1 Int)
(declare-var len Int)
(declare-var len1 Int)
(declare-var noDup Int)
(declare-var noDup1 Int)
(declare-var i Int)
(declare-var i1 Int)
(declare-var data Int)
(declare-var ret Int)
(declare-rel insert (Int Int Int Int Int Int Int Int Int))
(declare-rel search (Int Int Int Int Int))
(declare-rel inv1 (Int Int Int Int Int Int))
(declare-rel fail ())

(rule (=> (and (> N 0) (= max -10) (= min 10) (= len 0) (= noDup 1) (= i 0)) (inv1 i N max min len noDup)))

(rule (=> (and (inv1 i N max min len noDup) (is_valid noDup) (< i N) (insert i max min len noDup max1 min1 len1 noDup1) (= i1 (+ i 1))) (inv1 i1 N max1 min1 len1 noDup1)))

(rule (=> (and (inv1 i N max min len noDup) (is_valid noDup) (not (< i N)) (>= data 0) (< data N) (search data min max len ret) (= ret 0)) fail))
(query fail :print-certificate true)