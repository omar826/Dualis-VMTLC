(declare-var N Int)
(declare-var k Int)
(declare-var k1 Int)
(declare-var len Int)
(declare-var len1 Int)
(declare-var items_processed Int)
(declare-var items_processed1 Int)
(declare-var ret Int)
(declare-var ret1 Int)
(declare-var max Int)
(declare-var max1 Int)
(declare-rel insertHead (Int Int Int))
(declare-rel popHead (Int Int Int Int))
(declare-rel inv1 (Int Int Int))
(declare-rel inv2 (Int Int Int Int))
(declare-rel fail ())
(define-fun MAX () Int 128)
(define-fun MIN () Int -129)

(rule (=> (and (> N 0) (= k1 0) (= len1 0)) (inv1 k1 N len1)))
(rule (=> (and (inv1 k N len) (< k N) (insertHead k len len1) (= k1 (+ k 1))) (inv1 k1 N len1)))
(rule (=> (and (inv1 k N len) (not (< k N)) (= items_processed 0) (= ret1 MAX) (= max1 MIN)) (inv2 len items_processed max1 ret1)))
(rule (=> (and (inv2 len items_processed max ret) (not (= len 0)) (popHead len len1 max1 ret1) (= items_processed1 (+ items_processed 1))) (inv2 len1 items_processed1 max1 ret1)))
(rule (=> (and (inv2 len items_processed max ret) (= len 0) (not (= ret 0))) fail))

(query fail :print-certificate true)