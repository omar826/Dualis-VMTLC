(declare-var N Int)
(declare-var v Int)
(declare-var v1 Int)
(declare-var i Int)
(declare-var i1 Int)
(declare-var countvo Int)
(declare-var countvo1 Int)
(declare-var countvt Int)
(declare-var countvt1 Int)
(declare-var len Int)
(declare-var len1 Int)
(declare-rel emplace (Int Int Int Int Int Int Int))
(declare-rel emplace1 (Int Int Int Int Int Int Int))
(declare-rel inv1 (Int Int Int Int Int Int))
(declare-rel fail ())

(rule (=> (and (> N 0) (= v 1) (= i 0) (= countvo 0) (= countvt 0) (= len 0)) (inv1 i N v countvo countvt len)))
(rule (=> (and (inv1 i N v countvo countvt len) (< i N) (emplace v countvo countvt len countvo1 countvt1 len1) (= i1 (+ i 1))) (inv1 i1 N v countvo1 countvt1 len1)))
(rule (=> (and (inv1 i N v countvo countvt len) (not (< i N)) (= v1 2) (emplace1 v1 countvo countvt len countvo1 countvt1 len1) (not (and (= len1 (+ N 1)) (= countvt1 1)))) fail))

(query fail :print-certificate true)