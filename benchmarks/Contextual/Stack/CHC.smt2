(declare-var N Int)
(declare-var c Int)
(declare-var c1 Int)
(declare-var d Int)
(declare-var d1 Int)
(declare-var sl Int)
(declare-var sl1 Int)
(declare-rel pu (Int Int Int))
(declare-rel po (Int Int))
(declare-rel inv1 (Int Int Int Int))
(declare-rel inv2 (Int Int Int))
(declare-rel fail ())

(rule (=> (and (> N 0) (= c 0) (= d 0) (= sl 0)) (inv1 c N d sl)))
(rule (=> (and (inv1 c N d sl) (< c N) (pu N sl sl1) (= c1 (+ c 1))) (inv1 c1 N d sl1)))
(rule (=> (and (inv1 c N d sl) (not (< c N))) (inv2 N d sl)))
(rule (=> (and (inv2 N d sl) (not (= sl 0)) (po sl sl1) (= d1 (+ d 1))) (inv2 N d1 sl1)))
(rule (=> (and (inv2 N d sl) (= sl 0) (not (= d N))) fail))

(query fail :print-certificate true)
